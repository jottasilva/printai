  product_id String
  from_unit  String
  to_unit    String
  factor     Decimal   @db.Decimal(15, 6)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  products   Product   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
