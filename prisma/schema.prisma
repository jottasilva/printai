/// Plano de assinatura do tenant
enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

/// Status do tenant no sistema
enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELED
}

/// Papel do usuário dentro do tenant
enum UserRole {
  OWNER
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

/// Tipo de pessoa do cliente
enum DocumentType {
  CPF
  CNPJ
}

/// Tipo de endereço cadastrado
enum AddressType {
  BILLING
  SHIPPING
  BOTH
}

/// Tipo de produto no catálogo
enum ProductType {
  SIMPLE
  VARIABLE
  SERVICE
  BUNDLE
}

/// Tipo de movimentação de estoque
enum MovementType {
  IN
  OUT
  RESERVE
  RELEASE
  ADJUSTMENT
  LOSS
}

/// Status do orçamento no fluxo de vendas
enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

/// Status geral do pedido
enum OrderStatus {
  DRAFT
  CONFIRMED
  IN_PRODUCTION
  READY
  SHIPPED
  DELIVERED
  CANCELED
  REFUNDED
}

/// Status de pagamento do pedido
enum OrderPaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  REFUNDED
  CANCELED
}

/// Status de produção do pedido
enum ProductionStatus {
  WAITING
  IN_QUEUE
  PICKING
  IN_PROGRESS
  PACKING
  PAUSED
  DONE
  REJECTED
}

/// Status individual de cada item do pedido
enum OrderItemStatus {
  PENDING
  QUEUED
  PICKING
  IN_PROGRESS
  PACKING
  PAUSED
  DONE
  CANCELED
  REJECTED
  SHIPPED
}

/// Prioridade do item na produção
enum ItemPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

/// Método de pagamento aceito
enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  BOLETO
  CHECK
  OTHER
}

/// Status de pagamento (transação financeira)
enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELED
  REFUNDED
  CHARGEBACK
}

/// Status de conta a receber
enum ReceivableStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELED
  WRITTEN_OFF
}

/// Status de conta a pagar
enum PayableStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  CANCELED
}

/// Tipo de fluxo de caixa
enum CashFlowType {
  INFLOW
  OUTFLOW
}

/// Canal de atendimento ao cliente
enum ConversationChannel {
  WHATSAPP
  EMAIL
  CHAT
  SMS
  INSTAGRAM
  OTHER
}

/// Status da conversa no fluxo de atendimento
enum ConversationStatus {
  OPEN
  AI_HANDLING
  WAITING_HUMAN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

/// Papel da mensagem na conversa
enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

/// Tipo de conteúdo da mensagem
enum MessageContentType {
  TEXT
  IMAGE
  AUDIO
  DOCUMENT
  TEMPLATE
}

/// Status da assinatura do tenant
enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  PAUSED
  INCOMPLETE
}

/// Status do convite de equipe
enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELED
}

/// Nível de severidade do log
enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

/// Tipo de conta no Ledger (Ativo, Passivo, Receita, Despesa, Patrimônio)
enum LedgerAccountType {
  ASSET
  LIABILITY
  REVENUE
  EXPENSE
  EQUITY
}

/// Status da máquina
enum MachineStatus {
  OPERATIONAL
  DOWN
  MAINTENANCE
}

/// Nível de alerta de anomalia
enum AlertLevel {
  INFO
  WARNING
  CRITICAL
}
