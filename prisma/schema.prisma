  unit                                                     String   @default("un")
  notes                                                    String?
  created_at                                               DateTime @default(now()) @db.Timestamptz(6)
  updated_at                                               DateTime @default(now()) @db.Timestamptz(6)
  products_product_bom_items_material_product_idToproducts Product  @relation("product_bom_items_material_product_idToproducts", fields: [material_product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products_product_bom_items_product_idToproducts          Product  @relation("product_bom_items_product_idToproducts", fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
